{
  "routes": [
    {
      "route": "/*",
      "serve": "/index.php",
      "statusCode": 200
    }
  ],
  "platformErrorOverrides": [
    {
      "errorType": "NotFound",
      "serve": "/index.php",
      "statusCode": 200
    }
  ],
  "responseOverrides": {
    "403": {
      "statusCode": 200,
      "serve": "/index.php"
    }
  }
}
