{
  "password_reset_apis": {
    "endpoints": [
      {
        "name": "Request Password Reset",
        "method": "POST",
        "endpoint": "/api/auth/user/request_password_reset",
        "description": "Initiates password reset process by sending verification code to user's email",
        "request_body": {
          "email": "user@example.com"
        },
        "success_response": {
          "success": true,
          "message": "Password reset code sent to your email",
          "expires_at": "2024-01-01 10:15:00"
        },
        "error_responses": [
          {
            "status": 404,
            "response": {
              "success": false,
              "message": "User not found"
            }
          },
          {
            "status": 500,
            "response": {
              "success": false,
              "message": "Failed to send email"
            }
          }
        ]
      },
      {
        "name": "Verify Reset Code",
        "method": "POST",
        "endpoint": "/api/auth/user/verify_reset_code",
        "description": "Verifies the password reset code sent via email",
        "request_body": {
          "email": "user@example.com",
          "code": "123456"
        },
        "success_response": {
          "success": true,
          "message": "Verification code is valid"
        },
        "error_responses": [
          {
            "status": 400,
            "response": {
              "success": false,
              "message": "Invalid or expired verification code"
            }
          },
          {
            "status": 404,
            "response": {
              "success": false,
              "message": "User not found"
            }
          }
        ]
      },
      {
        "name": "Reset Password",
        "method": "POST",
        "endpoint": "/api/auth/user/reset_password",
        "description": "Completes password reset process with new password and valid code",
        "request_body": {
          "email": "user@example.com",
          "code": "123456",
          "new_password": "newSecurePassword123!"
        },
        "success_response": {
          "success": true,
          "message": "Password reset successfully"
        },
        "error_responses": [
          {
            "status": 400,
            "response": {
              "success": false,
              "message": "Invalid or expired verification code"
            }
          },
          {
            "status": 404,
            "response": {
              "success": false,
              "message": "User not found"
            }
          },
          {
            "status": 500,
            "response": {
              "success": false,
              "message": "Failed to update password"
            }
          }
        ]
      }
    ],
    "flow_example": {
      "step_1": {
        "description": "User requests password reset",
        "curl": "curl -X POST http://localhost/api/auth/user/request_password_reset -H 'Content-Type: application/json' -d '{\"email\":\"user@example.com\"}'"
      },
      "step_2": {
        "description": "User receives email with 6-digit verification code (valid for 15 minutes)"
      },
      "step_3": {
        "description": "User verifies the code (optional step for validation)",
        "curl": "curl -X POST http://localhost/api/auth/user/verify_reset_code -H 'Content-Type: application/json' -d '{\"email\":\"user@example.com\",\"code\":\"123456\"}'"
      },
      "step_4": {
        "description": "User resets password with code and new password",
        "curl": "curl -X POST http://localhost/api/auth/user/reset_password -H 'Content-Type: application/json' -d '{\"email\":\"user@example.com\",\"code\":\"123456\",\"new_password\":\"newSecurePassword123!\"}'"
      }
    },
    "security_features": [
      "6-digit verification codes",
      "15-minute code expiration",
      "Automatic cleanup of expired codes",
      "Email-based verification",
      "Secure password hashing with password_hash()",
      "Code validation before password update"
    ],
    "database_requirements": {
      "verification_code_table": {
        "fields": [
          "id (PRIMARY KEY)",
          "user_id (FOREIGN KEY to users.id)",
          "code (VARCHAR(6))",
          "type (VARCHAR(20) - 'password_reset')",
          "expires_at (TIMESTAMP)",
          "created_at (TIMESTAMP DEFAULT CURRENT_TIMESTAMP)"
        ]
      },
      "users_table": {
        "required_fields": [
          "id (PRIMARY KEY)",
          "email (UNIQUE)",
          "password_hash",
          "username"
        ]
      }
    }
  }
}
